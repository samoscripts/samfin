# Opcjonalna konfiguracja buildu APK (skopiuj do mobile/build.env — plik jest gitignored)
#
# Ścieżka do adb.exe na Windows (gdy auto-wykrywanie nie działa):
# ADB_WIN=/mnt/c/Users/48607/AppData/Local/Android/Sdk/platform-tools/adb.exe
#
# Folder Pobrane na Windows (make mobile-copy-apk):
# MOBILE_WIN_DOWNLOADS=/mnt/c/Users/48607/Downloads
#
# Android SDK w WSL (gdy inny niż ~/Android):
# ANDROID_HOME=/home/msamotyj/Android
