<IfModule mod_rewrite.c>
    RewriteEngine On

    # Pass Authorization header to PHP (Apache/LiteSpeed strips it with mod_rewrite)
    RewriteCond %{HTTP:Authorization} .
    RewriteRule .* - [E=HTTP_AUTHORIZATION:%{HTTP:Authorization}]

    # 1. Serve existing files and directories as-is
    RewriteCond %{REQUEST_FILENAME} -f [OR]
    RewriteCond %{REQUEST_FILENAME} -d
    RewriteRule ^ - [L]

    # Root → SPA entry point
    RewriteRule ^$ /app/ [R=302,L]

    # 2. React SPA — /app/* routes fallback to /app/index.html
    RewriteRule ^app(/.*)?$ /app/index.html [L]

    # 3. Symfony API — everything else goes to index.php
    RewriteRule ^ index.php [L]
</IfModule>
