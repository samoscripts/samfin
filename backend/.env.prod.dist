# Production template — copy to .env on server and fill in secrets.
# Path on server: /home/mjmvszga/public_html/samfin/backend/.env

APP_ENV=prod
APP_DEBUG=0
APP_SECRET=change-me-to-random-string

# Use actual MySQL version from hosting (mysql --version)
DATABASE_URL="mysql://USER:PASSWORD@localhost:3306/DATABASE?serverVersion=8.0.36&charset=utf8mb4"

# Required by nelmio_cors.yaml; same-origin SPA rarely triggers CORS
CORS_ALLOW_ORIGIN='^https?://fin\.samsoft\.pl$'
