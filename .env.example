# Host user for Docker frontend service (avoids root-owned files in frontend/).
# Linux/WSL: copy to .env and set your ids: HOST_UID=$(id -u) HOST_GID=$(id -g)
#
# If frontend fails with EACCES on node_modules after changing HOST_UID, run once:
#   make fix-frontend-node-modules
HOST_UID=1000
HOST_GID=1000
